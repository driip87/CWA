{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Cordova Waste App (customer or admin)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Pickup": {
      "title": "Pickup",
      "description": "A scheduled waste pickup",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user requesting the pickup" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] },
        "date": { "type": "string", "format": "date-time" },
        "binLocation": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "date", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "failed"] },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["userId", "amount", "status", "date"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Asset tracking for bins, vehicles, and equipment",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["bin", "vehicle", "equipment"] },
        "status": { "type": "string", "enum": ["active", "maintenance", "retired"] },
        "location": { "type": "string" },
        "coordinates": { "type": "string", "description": "Lat,Lng coordinates" },
        "assignedTo": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "status", "lastUpdated"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense record",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["amount", "category", "date"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "A customer interaction or service request note",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["note", "call", "email", "service_request"] },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "resolved"] }
      },
      "required": ["userId", "type", "content", "date", "authorId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "pickups/{pickupId}": {
      "schema": { "$ref": "#/entities/Pickup" },
      "description": "Scheduled pickups"
    },
    "payments/{paymentId}": {
      "schema": { "$ref": "#/entities/Payment" },
      "description": "Payment records"
    },
    "inventory/{itemId}": {
      "schema": { "$ref": "#/entities/Inventory" },
      "description": "Inventory and asset tracking"
    },
    "expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Business expenses"
    },
    "interactions/{interactionId}": {
      "schema": { "$ref": "#/entities/Interaction" },
      "description": "Customer interactions and notes"
    }
  }
}
