rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "kereeonmiller@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'email', 'name', 'role', 'phone', 'address', 'createdAt']) &&
             request.resource.data.uid is string &&
             request.resource.data.email is string &&
             request.resource.data.role in ['user', 'admin'] &&
             request.resource.data.createdAt is string;
    }

    function isValidPickup() {
      return hasOnlyAllowedFields(['userId', 'status', 'date', 'binLocation', 'notes', 'createdAt']) &&
             request.resource.data.userId is string &&
             request.resource.data.status in ['scheduled', 'completed', 'cancelled'] &&
             request.resource.data.date is string &&
             request.resource.data.createdAt is string;
    }

    function isValidPayment() {
      return hasOnlyAllowedFields(['userId', 'amount', 'status', 'date', 'description']) &&
             request.resource.data.userId is string &&
             request.resource.data.amount is number &&
             request.resource.data.status in ['paid', 'pending', 'failed'] &&
             request.resource.data.date is string;
    }

    function isValidInventory() {
      return hasOnlyAllowedFields(['type', 'status', 'location', 'coordinates', 'assignedTo', 'lastUpdated']) &&
             request.resource.data.type in ['bin', 'vehicle', 'equipment'] &&
             request.resource.data.status in ['active', 'maintenance', 'retired'] &&
             request.resource.data.lastUpdated is string;
    }

    function isValidExpense() {
      return hasOnlyAllowedFields(['amount', 'category', 'date', 'description']) &&
             request.resource.data.amount is number &&
             request.resource.data.category is string &&
             request.resource.data.date is string;
    }

    function isValidInteraction() {
      return hasOnlyAllowedFields(['userId', 'type', 'content', 'date', 'authorId']) &&
             request.resource.data.userId is string &&
             request.resource.data.type in ['note', 'call', 'email', 'service_request'] &&
             request.resource.data.content is string &&
             request.resource.data.date is string &&
             request.resource.data.authorId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser() && uidUnchanged() && (
        (isOwner(userId) && request.resource.data.role == 'user') || isAdmin()
      );
      allow update: if isAuthenticated() && isValidUser() && uidNotModified() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /pickups/{pickupId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidPickup() && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isAuthenticated() && isValidPickup() && (
        (request.resource.data.userId == resource.data.userId && request.auth.uid == resource.data.userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidPayment() && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isAdmin() && isValidPayment();
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read, write: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    match /interactions/{interactionId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid && request.resource.data.authorId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
