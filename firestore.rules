rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function accountDoc() {
      return get(/databases/$(database)/documents/accounts/$(request.auth.uid));
    }

    function hasAccount() {
      return isAuthenticated() && exists(/databases/$(database)/documents/accounts/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() && (
        (hasAccount() && accountDoc().data.role == 'admin') ||
        (request.auth.token.email == "kereeonmiller@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function linkedCustomerId() {
      return hasAccount() ? accountDoc().data.customerId : null;
    }

    function isLinkedCustomer(customerId) {
      return hasAccount() && linkedCustomerId() == customerId;
    }

    function userEditableFieldsOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'name',
        'phone',
        'address',
        'normalizedPhone',
        'normalizedAddress'
      ]);
    }

    match /accounts/{accountId} {
      allow read: if isAuthenticated() && (request.auth.uid == accountId || isAdmin());
      allow write: if false;
    }

    match /claimInvites/{inviteId} {
      allow read, write: if false;
    }

    match /users/{customerId} {
      allow read: if isLinkedCustomer(customerId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isLinkedCustomer(customerId) && userEditableFieldsOnly());
      allow delete: if isAdmin();
    }

    match /pickups/{pickupId} {
      allow read: if isAuthenticated() && (isLinkedCustomer(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && ((hasAccount() && request.resource.data.userId == linkedCustomerId()) || isAdmin());
      allow update: if isAuthenticated() && ((hasAccount() && resource.data.userId == linkedCustomerId() && request.resource.data.userId == resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (isLinkedCustomer(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && ((hasAccount() && request.resource.data.userId == linkedCustomerId()) || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read, write: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    match /interactions/{interactionId} {
      allow read: if isAdmin() || (isAuthenticated() && isLinkedCustomer(resource.data.userId));
      allow create: if isAdmin() || (
        isAuthenticated() &&
        hasAccount() &&
        request.resource.data.userId == linkedCustomerId() &&
        request.resource.data.authorId == linkedCustomerId()
      );
      allow update, delete: if isAdmin();
    }
  }
}
